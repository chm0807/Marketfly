{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MarketFlow Pi",
  "version": "0.1.0",
  "identifier": "com.marketflow.pi",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MarketFlow Pi",
        "width": 1180,
        "height": 760,
        "minWidth": 360,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": false
  }
}
